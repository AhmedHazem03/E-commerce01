# ─────────────────────────────────────────────────────────────────────────────
# E-Commerce Store MVP — Environment Variables Template
# Branch: 001-e-commerce-store
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase / PostgreSQL ────────────────────────────────────────────────────
# Pooled connection string (used by Prisma at runtime in serverless envs)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection string (used by prisma migrate dev / prisma migrate deploy)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Secret for signing admin JWT tokens (HS256). Min 32 random chars.
JWT_SECRET="replace-with-a-long-random-string-min-32-chars"

# Secret checked in the Vercel Cron endpoint before any DB work.
CRON_SECRET="replace-with-another-long-random-string"

# ── App ───────────────────────────────────────────────────────────────────────
# Full public URL of the site (no trailing slash)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
# Used once by bootstrapAdmin() to seed the first Admin row.
# Change these IMMEDIATELY after first login via the Settings page.
ADMIN_PHONE="01000000000"
ADMIN_PASSWORD="ChangeMe123!"
